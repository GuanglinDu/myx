# Files in any directory level
.DS_Store
.stignore
*.pyc
*.sw?
# The IDE workspace files
*.code-workspace
*.theia-workspace
README_private.md

# Test coverage reports at any directory level
**/coverage
**/.coverage

# Possible IDE settings at any directory level
# The trailing / ensures that only directories are ignored.
.idea/
.vscode/
.theia/
.mypy_cache/
.pytest_cache/
.stfolder/

# Ignores any directory at any level. The trailing / matters!
__pycache__/
node_modules/

# Frequently changing files
**/db.sqlite3
**/media/
**/migrations/*.py
!**/migrations/__init__.py

# Temporary folders & files
tmp/
temp/

# Ignores Tauri build output which can be large!
**/src-tauri/target/
**/tests/report.html
