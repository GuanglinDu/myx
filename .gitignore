# Already tracked files:
# .gitignore only applies to untracked files. If a file was committed to the
# repository before it was added to .gitignore, it will continue to be tracked.
# To untrack it while keeping it on your local disk, run:
#   git rm --cached <file-name>, or
#   git rm -r --cached <directory-name>
# 
# See https://git-scm.com/docs/gitignore for more details.
# (0) Ignore a specific file anywhere in the repository with its filename
# (a global match), e.g., secret.json ignore secret.json, src/secret.json,
# config/dev/secret.json, etc., equivalent to **/secret.json.
# (1) * matches anything except a slash /.
# (2) ? matches any one character except "/".
# (3) **/foo matches file or directory "foo" anywhere, the same as pattern
#  "foo".
# (4) **/*.log is functionally identical to writing *.log. Both rules tell Git
# to ignore all files ending in .log throughout the entire repository.
# (5) **/foo/bar" matches file or directory "bar" anywhere that is directly
# under directory "foo".
# (6) config/** ensures every file and subfolder inside the root config folder
# is ignored.
# (7) A trailing "/**" matches everything inside. For example, "abc/**" matches
# all files inside directory "abc", relative to the location of the .gitignore
# file, with infinite depth.
# (8) A slash followed by two consecutive asterisks then a slash matches zero or
# more directories. For example, "a/**/b" matches "a/b", "a/x/b", "a/x/y/b" and
# so on, e.g., src/**/test/ matches src/test/, src/components/test/, or
# src/utils/handlers/test/.

# Files in any directory level
# ====================
# OS & Editor Files
# ====================
.DS_Store
Thumbs.db

# IDE workspace files
*.code-workspace
*.theia-workspace

# ====================
# Language-Specific
# ====================
# Python
*.pyc
*.pyo
*.pyd
.Python
*.sw?
*.so
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
__pycache__/
db.sqlite3
coverage/
.coverage

# Node dependencies anywhere in the repository
node_modules/

# ====================
# IDE Settings
# ====================
# Ignore personal VS Code workspace configurations
.vscode/*

# But do track shared team configurations
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.idea/
.theia/
# Config for syncthing (if used for syncing)
.stfolder/
.stignore

# ====================
# Project-Specific
# ====================
# Django/DRF silk
media/
static/

# Migrations (keep __init__.py)
**/migrations/*.py
!**/migrations/__init__.py

# Tauri
**/src-tauri/target/

# ====================
# Temporary
# ====================
tmp/
temp/
logs/

